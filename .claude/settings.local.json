{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git init:*)",
      "Bash(git remote add:*)",
      "Bash(md5sum:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(bash:*)",
      "Bash(awk:*)",
      "Bash(dir:*)",
      "Bash(du:*)",
      "Bash(mkdir:*)",
      "Bash(python3:*)",
      "Read(//c/Users/chath/OneDrive/Documents/Python code/**)",
      "WebSearch",
      "Bash(powershell -Command \"Get-ChildItem -Path ''$env:USERPROFILE\\\\OneDrive'' -Directory | ForEach-Object { $size = \\(Get-ChildItem $_FullName -Recurse -File -ErrorAction SilentlyContinue | Measure-Object -Property Length -Sum\\).Sum; [PSCustomObject]@{Folder=$_Name; SizeMB=[math]::Round\\($size/1MB,1\\)} } | Sort-Object SizeMB -Descending | Format-Table -AutoSize\")",
      "Bash(/tmp/cleanup_round2.ps1:*)",
      "Bash(powershell.exe -NoProfile -ExecutionPolicy Bypass -File /tmp/cleanup_round2.ps1)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/workflow-enforcer.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-partition-edits.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact-save.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-learning-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
